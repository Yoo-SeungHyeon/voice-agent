{
  "name": "voice-agent",
  "displayName": "Voice Agent",
  "description": "Control VSCode with a Python/Agno natural-language voice agent.",
  "version": "0.2.0",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onCommand:voiceAgent.openPanel",
    "onCommand:voiceAgent.runCommand",
    "onCommand:voiceAgent.showContext",
    "onCommand:voiceAgent.connectExternalInput"
  ],
  "contributes": {
    "commands": [
      {
        "command": "voiceAgent.openPanel",
        "title": "Voice Agent: Open Command Panel"
      },
      {
        "command": "voiceAgent.runCommand",
        "title": "Voice Agent: Run Text Command"
      },
      {
        "command": "voiceAgent.showContext",
        "title": "Voice Agent: Show Current Context"
      },
      {
        "command": "voiceAgent.connectExternalInput",
        "title": "Voice Agent: Show External Input QR"
      }
    ],
    "configuration": {
      "title": "Voice Agent",
      "properties": {
        "voiceAgent.autonomousMode": {
          "type": "boolean",
          "default": true,
          "description": "Run recognized commands immediately without confirmation."
        },
        "voiceAgent.externalInputUrl": {
          "type": "string",
          "default": "http://localhost:4317/voice-agent",
          "description": "URL shown as a QR code for future mobile or external voice input flows."
        },
        "voiceAgent.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to run the Agno voice-agent bridge."
        }
      }
    }
  },
  "scripts": {
    "test": "node test/agent.test.js && python -m unittest discover -s tests",
    "test:js": "node test/agent.test.js",
    "test:py": "python -m unittest discover -s tests",
    "package:check": "node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8')); console.log('package.json ok')\""
  }
}
